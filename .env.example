# ============================================================
# .env.example — Copiar a .env y ajustar valores locales
# ============================================================

# --- PostgreSQL ---
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=reservas_de_coworking_db

# --- Backend (NestJS) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reservas_de_coworking_db
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1




